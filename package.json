{
  "name": "adalab-shield",
  "displayName": "adalab shield",
  "version": "0.2.0",
  "description": "Site & short-form video blocker that guards your focus. Syncs with the adalab study pomodoro: block during focus, unblock during breaks.",
  "type": "module",
  "private": true,
  "author": "Adabana Saki <yuuto819midorimatu@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/adabana-saki/adalab-shield#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/adabana-saki/adalab-shield.git"
  },
  "bugs": {
    "url": "https://github.com/adabana-saki/adalab-shield/issues"
  },
  "keywords": [
    "browser-extension",
    "productivity",
    "focus",
    "youtube-shorts",
    "tiktok",
    "instagram-reels",
    "content-blocker",
    "pomodoro",
    "time-tracking",
    "habit-tracking",
    "distraction-blocker",
    "chrome-extension",
    "firefox-addon",
    "edge-extension"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:chrome": "cross-env BROWSER=chrome vite build",
    "build:firefox": "cross-env BROWSER=firefox vite build",
    "build:edge": "cross-env BROWSER=edge vite build",
    "build:all": "pnpm build:chrome && pnpm build:firefox && pnpm build:edge",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm build:chrome && playwright test",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit",
    "i18n:check": "tsx scripts/i18n-check.ts",
    "i18n:extract": "tsx scripts/i18n-extract.ts",
    "manifest:sync": "tsx scripts/manifest-transform.ts sync",
    "manifest:to-firefox": "tsx scripts/manifest-transform.ts to-firefox",
    "manifest:to-chrome": "tsx scripts/manifest-transform.ts to-chrome",
    "manifest:validate": "tsx scripts/manifest-transform.ts validate",
    "icons:generate": "tsx scripts/generate-icons.ts",
    "prepare": "husky",
    "release": "pnpm build:all && pnpm test:unit",
    "audit:security": "pnpm audit --audit-level=moderate"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.6.1",
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9",
    "@playwright/test": "^1.60.0",
    "@types/chrome": "^0.1.43",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/webextension-polyfill": "^0.12.5",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^2.1.5",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.1",
    "globals": "^15",
    "husky": "^9.1.6",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
