{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "version": "0.2.0",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "shortshield@adabana-saki.github.io",
      "strict_min_version": "112.0",
      "data_collection_permissions": {
        "required": []
      }
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "__MSG_extensionName__"
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "background": {
    "scripts": ["src/background/index.ts"],
    "type": "module"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+S" },
      "description": "__MSG_commandOpenPopup__"
    },
    "toggle-blocking": {
      "suggested_key": { "default": "Ctrl+Shift+Y" },
      "description": "__MSG_commandToggleBlocking__"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.tiktok.com/*",
        "*://*.instagram.com/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "*://*.facebook.com/*",
        "*://*.linkedin.com/*",
        "*://*.threads.net/*",
        "*://*.snapchat.com/*",
        "*://*.reddit.com/*",
        "*://study.adalabtech.com/*",
        "*://localhost/*",
        "*://127.0.0.1/*"
      ],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "alarms",
    "notifications",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.tiktok.com/*",
    "*://*.instagram.com/*",
    "*://*.twitter.com/*",
    "*://*.x.com/*",
    "*://*.facebook.com/*",
    "*://*.linkedin.com/*",
    "*://*.threads.net/*",
    "*://*.snapchat.com/*",
    "*://*.reddit.com/*",
    "*://study.adalabtech.com/*",
    "*://localhost/*",
    "*://127.0.0.1/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "blocked.html", "blocked.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
